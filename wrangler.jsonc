{
    "name": "richrix-mailbox-cloudflare",
    "main": "src/index.ts",
    "compatibility_date": "2026-03-30",
    "vars": {
        "MAILBOX_ENDPOINT": "",
    },
    "secrets_store_secrets": [
        {
            "binding": "MAILBOX_SECRET",
            "store_id": "richrix",
            "secret_name": "mailbox-inbound-secret"
        }
    ]
}
